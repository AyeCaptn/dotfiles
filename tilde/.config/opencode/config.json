{
  "$schema": "https://opencode.ai/config.json",
  "theme": "catppuccin-macchiato",
  "autoshare": false,
  "autoupdate": true,
  "mcp": {
    "shadcn": {
      "type": "local",
      "command": ["npx", "shadcn@latest", "mcp"],
      "enabled": true
